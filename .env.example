# Get your free API key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: if YouTube blocks this IP (e.g. on Streamlit Cloud), use a proxy.
#
# --- Webshare free 10 proxies ---
# In Webshare dashboard you get a list of proxies (host:port) and a username/password.
# Build one URL per proxy: http://USERNAME:PASSWORD@host:port
# Put all 10 URLs in one line, comma-separated; the app will pick one at random each time:
#
# YT_PROXY=http://your_username:your_password@proxy1.webshare.io:80,http://your_username:your_password@proxy2.webshare.io:80,...
#
# Or use a single proxy:
# YT_PROXY=http://your_username:your_password@proxy-host:port
#
# --- Webshare rotating residential (paid) ---
# YT_WEBSHARE_USERNAME=your_username
# YT_WEBSHARE_PASSWORD=your_password
